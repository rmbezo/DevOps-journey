 # Берём официальный образ Python 3.11 в минимальной конфигурации
 FROM python:3.11-slim

 # Копируем файл приложения в рабочую директорию контейнера
 COPY app.py /app/app.py

 # Устанавливаем рабочую директорию
 WORKDIR /app
 
 # Определяем команду по умолчанию: запуск нашего приложения
 CMD ["python", "app.py"]